# ============================================================
# THEJA — Staging Environment Variables
# File: infra/staging.env.example
#
# Copia questo file in /var/www/theja/apps/api/.env sul server
# staging e sostituisci TUTTI i placeholder con i valori reali.
#
# ATTENZIONE: non committare mai il file .env reale.
# ============================================================

# ─── Applicazione ─────────────────────────────────────────────
APP_NAME=Theja
APP_ENV=staging
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_TIMEZONE=Europe/Rome
APP_URL=https://api-staging.theja.it

# ─── Localizzazione ──────────────────────────────────────────
APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

# ─── Log ──────────────────────────────────────────────────────
# In staging: single file. In prod usare 'stack' con Sentry.
LOG_CHANNEL=single
LOG_LEVEL=debug

# ─── Database — AWS RDS PostgreSQL 16 ─────────────────────────
# Trova l'endpoint in: AWS Console → RDS → Databases → theja-staging
DB_CONNECTION=pgsql
DB_HOST=theja-staging.XXXXXXXXXX.eu-south-1.rds.amazonaws.com
DB_PORT=5432
DB_DATABASE=theja
DB_USERNAME=theja
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Redis — AWS ElastiCache (Valkey/Redis 7) ─────────────────
# Trova l'endpoint in: AWS Console → ElastiCache → theja-staging
REDIS_CLIENT=predis
REDIS_HOST=theja-staging.XXXXXX.0001.eun1.cache.amazonaws.com
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Cache ────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=theja_staging_

# ─── Session ─────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.theja.it

# ─── Queue ────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ─── Broadcasting (Soketi su EC2 staging) ────────────────────
# Soketi gira sullo stesso EC2 sulla porta 6001
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=theja-staging
PUSHER_APP_KEY=CHANGE_ME_SOKETI_APP_KEY
PUSHER_APP_SECRET=CHANGE_ME_SOKETI_APP_SECRET
PUSHER_HOST=api-staging.theja.it
PUSHER_PORT=6001
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# ─── Mail — AWS SES (eu-south-1) ─────────────────────────────
MAIL_MAILER=ses
MAIL_FROM_ADDRESS="noreply@staging.theja.it"
MAIL_FROM_NAME="Theja Staging"

# ─── AWS ──────────────────────────────────────────────────────
# IAM role con permessi: ses:SendEmail, s3:PutObject, s3:GetObject, s3:DeleteObject
AWS_ACCESS_KEY_ID=AKIA_CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET
AWS_DEFAULT_REGION=eu-south-1
AWS_BUCKET=theja-staging-storage
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Filesystem ──────────────────────────────────────────────
FILESYSTEM_DISK=s3

# ─── Sanctum ─────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=staging.theja.it

# ─── Stripe Billing ──────────────────────────────────────────
# Usa chiavi TEST per staging — mai chiavi LIVE
STRIPE_KEY=pk_test_CHANGE_ME
STRIPE_SECRET=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_BASE=price_CHANGE_ME_base_per_pos
STRIPE_PRICE_SESSION_ADDON=price_CHANGE_ME_session_addon
STRIPE_PRICE_AI_ANALYSIS=price_CHANGE_ME_ai_analysis

# ─── Vite (non usato in produzione — solo per riferimento) ───
VITE_APP_NAME="${APP_NAME}"

# ============================================================
# CHECKLIST PRIMO DEPLOY STAGING
# ============================================================
# [ ] Creare utente IAM dedicato con policy minima
# [ ] Configurare RDS: VPC privata, security group solo dall'EC2
# [ ] Configurare ElastiCache: stessa VPC dell'EC2
# [ ] Generare APP_KEY: php artisan key:generate --show
# [ ] Generare PUSHER_APP_KEY/SECRET: openssl rand -hex 32
# [ ] Configurare DNS: api-staging.theja.it → EC2 public IP
# [ ] Ottenere certificato SSL: certbot --nginx -d api-staging.theja.it
# [ ] Eseguire migrazioni: php artisan migrate --force
# [ ] Creare utente admin: php artisan db:seed --class=DatabaseSeeder
# [ ] Configurare cron per scheduler: * * * * * php artisan schedule:run
# [ ] Configurare supervisord per queue worker
# ============================================================
