# ============================================================
# THEJA — apps/api/.env.example
# Copia in .env e personalizza i valori per il tuo ambiente.
# Esegui `php artisan key:generate` dopo la copia.
# ============================================================

# ─── Applicazione ────────────────────────────────────────────
APP_NAME=Theja
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Rome
APP_URL=http://localhost:8000

# ─── Localizzazione ──────────────────────────────────────────
APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

# ─── Log ─────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database principale (PostgreSQL 16) ─────────────────────
# Ogni Organization ha il proprio schema PostgreSQL: tenant_{org_id}
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5434
DB_DATABASE=theja
DB_USERNAME=theja
DB_PASSWORD=secret

# ─── Redis (Cache + Queue + Session) ─────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Cache ───────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=theja_

# ─── Session ─────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Queue ───────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ─── Broadcasting (Soketi self-hosted) ───────────────────────
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=theja
PUSHER_APP_KEY=theja-key
PUSHER_APP_SECRET=theja-secret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# ─── Mail ────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@theja.it"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS (Storage S3 + SES) ──────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-south-1
AWS_BUCKET=theja-storage
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Filesystem ──────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── Sanctum (Auth API) ──────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# ─── OpenAI (OCR ricette / GPT-4o Vision) ─────────────────────
OPENAI_API_KEY=

# ─── Stripe Billing ──────────────────────────────────────────
# Chiavi test da Stripe Dashboard → Developers → API Keys
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
# Segreto webhook: Stripe Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_
# ID prezzi Stripe (test mode)
STRIPE_PRICE_BASE=price_base_per_pos
STRIPE_PRICE_SESSION_ADDON=price_session_addon
STRIPE_PRICE_AI_ANALYSIS=price_ai_analysis

# ─── Vite ────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
