# ============================================================
# THEJA — apps/api/.env.testing
# Ambiente di test con PostgreSQL database theja_test.
# Usato da `php artisan test` e dalla pipeline CI/CD.
# ============================================================

APP_NAME=Theja
APP_ENV=testing
APP_KEY=base64:placeholder_key_generated_by_artisan_key_generate
APP_DEBUG=true
APP_TIMEZONE=Europe/Rome
APP_URL=http://localhost:8000

APP_LOCALE=it
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=single
LOG_LEVEL=error

# ─── Database di test (PostgreSQL 16) ────────────────────────
# Database separato per evitare contaminazione dati produzione/sviluppo
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=theja_test
DB_USERNAME=theja
DB_PASSWORD=secret

# ─── Redis (istanza separata per test) ───────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

# ─── Broadcasting disabilitato nei test ──────────────────────
BROADCAST_CONNECTION=log

# ─── Mail intercettata nei test ──────────────────────────────
MAIL_MAILER=array

# ─── AWS mock nei test ───────────────────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=eu-south-1
AWS_BUCKET=theja-test-storage
FILESYSTEM_DISK=local

# ─── Sanctum ─────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000
