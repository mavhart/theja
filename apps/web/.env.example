# ============================================================
# THEJA — apps/web/.env.example
# Copia in .env.local e personalizza i valori.
# Le variabili NEXT_PUBLIC_* sono esposte al browser.
# ============================================================

# ─── API Backend ─────────────────────────────────────────────
# URL dell'API Laravel (apps/api)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── WebSocket (Soketi) ──────────────────────────────────────
# App key configurata in apps/api/.env (PUSHER_APP_KEY)
NEXT_PUBLIC_SOKETI_KEY=theja-key
# Host Soketi (default: localhost in sviluppo)
NEXT_PUBLIC_SOKETI_HOST=localhost
# Porta Soketi
NEXT_PUBLIC_SOKETI_PORT=6001
